// ============================================================
// CHAPTER COLORS CONFIG
const CH_CONFIG = {
  1: { color: '#e67e22', bg: '#fef3e2', btnActive: '#fde8c8' },
  2: { color: '#27ae60', bg: '#e8f8ef', btnActive: '#d0f0df' },
  3: { color: '#2980b9', bg: '#e8f4fc', btnActive: '#cce8f7' },
  4: { color: '#8e44ad', bg: '#f3e8fc', btnActive: '#e8d4f8' },
  5: { color: '#c0392b', bg: '#fde8e6', btnActive: '#fbd0cc' },
};

let activeChapter = null;
let activeLesson = null;

function toggleChapter(ch) {
  const panel = document.getElementById('panel-ch' + ch);
  const card = document.querySelector('.chapter-card[data-ch="' + ch + '"]');

  if (activeChapter === ch) {
    // Close
    panel.classList.remove('open');
    card.classList.remove('active');
    activeChapter = null;
    activeLesson = null;
    return;
  }

  // Close previous
  if (activeChapter) {
    document.getElementById('panel-ch' + activeChapter).classList.remove('open');
    document.querySelector('.chapter-card[data-ch="' + activeChapter + '"]').classList.remove('active');
  }

  activeChapter = ch;
  activeLesson = null;
  panel.classList.add('open');
  card.classList.add('active');

  // Scroll to panel
  setTimeout(() => panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
}

function showMindmap(chId, lessonId, lessonName) {
  const key = chId + '-' + lessonId;
  const mmViewer = document.getElementById('mm-' + chId);
  const chNum = parseInt(chId.replace('ch',''));

  // Deactivate previous lesson buttons
  document.querySelectorAll('#panel-' + chId + ' .lesson-btn').forEach(b => b.classList.remove('active'));
  // Activate current
  event.currentTarget.classList.add('active');

  if (activeLesson === key) {
    mmViewer.classList.remove('open');
    mmViewer.innerHTML = '';
    activeLesson = null;
    return;
  }

  activeLesson = key;
  mmViewer.classList.add('open');

  const data = MINDMAP_DATA[key];
  const cfg = CH_CONFIG[chNum];

  if (!data) {
    mmViewer.innerHTML = `
      <div class="mindmap-viewer-header">
        <div class="mindmap-viewer-title">Bài ${lessonId.replace('b','')} — ${lessonName}</div>
      </div>
      <div class="mindmap-container">
        <div class="mindmap-placeholder">
          <div class="mindmap-placeholder-icon">🗂️</div>
          <p>Sơ đồ tư duy cho bài này đang được cập nhật</p>
          <div class="update-note">📥 Nội dung từ NotebookLM sẽ được thêm vào tại hàm <code>getMindmapData()</code></div>
        </div>
      </div>`;
    return;
  }

  mmViewer.innerHTML = `
    <div class="mindmap-viewer-header">
      <div>
        <div class="mindmap-viewer-title">
          Bài ${lessonId.replace('b','')} — ${data.title}
          <small>Sơ đồ tư duy tóm tắt</small>
        </div>
      </div>
      <div class="mindmap-actions">
        <button class="mindmap-btn" onclick="window.print()">🖨️ In</button>
      </div>
    </div>
    <div class="mindmap-container">
      <div class="mindmap-wrap">
        ${buildMindmapSVG(data, cfg)}
      </div>
    </div>`;

  setTimeout(() => mmViewer.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 100);
}

function buildMindmapSVG(data, cfg) {
  const branches = data.branches;
  const W = Math.max(900, 200 + branches.length * 220);
  const H = 420;
  const cx = W / 2;
  const cy = H / 2;
  const branchSpacing = W / (branches.length + 1);

  let svgContent = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" class="mindmap-svg" style="min-width:${W}px">
    <defs>
      <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="2" dy="3" stdDeviation="4" flood-color="rgba(0,0,0,0.15)"/>
      </filter>
    </defs>`;

  // Center node
  const centerW = 160; const centerH = 56;
  svgContent += `
    <rect x="${cx - centerW/2}" y="${cy - centerH/2}" width="${centerW}" height="${centerH}" rx="28" fill="${cfg.color}" filter="url(#shadow)"/>
    <text x="${cx}" y="${cy - 8}" text-anchor="middle" font-family="Crimson Pro, serif" font-weight="700" font-size="13" fill="white">${wrapText(data.title, 20, 0)}</text>
    <text x="${cx}" y="${cy + 10}" text-anchor="middle" font-family="Crimson Pro, serif" font-weight="700" font-size="13" fill="white">${wrapText(data.title, 20, 1)}</text>`;

  branches.forEach((branch, i) => {
    const bx = branchSpacing * (i + 1);
    const by = cy;
    const bW = 140; const bH = 38;

    // Line from center to branch
    svgContent += `<line x1="${cx}" y1="${cy}" x2="${bx}" y2="${by}" stroke="${branch.color}" stroke-width="2.5" opacity="0.5" stroke-dasharray="5,3"/>`;

    // Branch node
    svgContent += `
      <rect x="${bx - bW/2}" y="${by - bH/2}" width="${bW}" height="${bH}" rx="10" fill="${branch.color}" filter="url(#shadow)"/>`;

    const bLabel = branch.label.length > 18 ? branch.label.substring(0, 17) + '…' : branch.label;
    svgContent += `<text x="${bx}" y="${by + 5}" text-anchor="middle" font-family="Be Vietnam Pro, sans-serif" font-size="11" fill="white" font-weight="600">${bLabel}</text>`;

    // Sub nodes — distribute vertically
    const subsCount = branch.subs.length;
    const subSpread = Math.min(subsCount * 42, 170);
    branch.subs.forEach((sub, j) => {
      const subY = by - subSpread/2 + (j / Math.max(subsCount - 1, 1)) * subSpread;
      const subX = bx + (bx < cx ? -90 : 90);
      const sW = 140; const sH = 28;

      svgContent += `<line x1="${bx + (bx < cx ? -bW/2 : bW/2)}" y1="${by}" x2="${subX}" y2="${subY}" stroke="${branch.color}" stroke-width="1.5" opacity="0.3"/>`;
      svgContent += `
        <rect x="${subX - sW/2}" y="${subY - sH/2}" width="${sW}" height="${sH}" rx="6" fill="white" stroke="${branch.color}" stroke-width="1.5"/>`;

      const subLabel = sub.length > 20 ? sub.substring(0, 19) + '…' : sub;
      svgContent += `<text x="${subX}" y="${subY + 4}" text-anchor="middle" font-family="Be Vietnam Pro, sans-serif" font-size="9.5" fill="#333">${subLabel}</text>`;
    });
  });

  svgContent += `</svg>`;
  return svgContent;
}

function wrapText(text, maxLen, line) {
  if (text.length <= maxLen) return line === 0 ? text : '';
  const words = text.split(' ');
  let line0 = '', line1 = '';
  for (const w of words) {
    if ((line0 + ' ' + w).trim().length <= maxLen) line0 = (line0 + ' ' + w).trim();
    else line1 = (line1 + ' ' + w).trim();
  }
  return line === 0 ? line0 : line1;
}
