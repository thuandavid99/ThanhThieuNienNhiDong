<!DOCTYPE html>
<html lang="vi">
<%- include('../partials/head') %>
<body>
<%- include('../partials/header') %>

<style>
  /* ===== LỊCH SỬ 6 — KIẾN TRÚC THÔNG MINH ===== */
  @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap');

  :root {
    --ls6-gold: #c8a84b;
    --ls6-gold-light: #f0d88a;
    --ls6-brown: #6b4c2a;
    --ls6-cream: #fdf6e9;
    --ls6-ink: #1a1208;
    --ls6-slate: #4a5568;
    --ls6-red: #c0392b;
    --ch1: #e67e22; --ch1-bg: #fef3e2;
    --ch2: #27ae60; --ch2-bg: #e8f8ef;
    --ch3: #2980b9; --ch3-bg: #e8f4fc;
    --ch4: #8e44ad; --ch4-bg: #f3e8fc;
    --ch5: #c0392b; --ch5-bg: #fde8e6;
  }

  .ls6-page { font-family: 'Be Vietnam Pro', sans-serif; background: var(--ls6-cream); min-height: 100vh; }

  /* HERO */
  .ls6-hero {
    background: linear-gradient(135deg, #1a0a02 0%, #3d1f06 40%, #6b3d12 100%);
    padding: 64px 0 48px;
    position: relative; overflow: hidden;
  }
  .ls6-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c8a84b' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .ls6-hero .container { position: relative; }
  .ls6-breadcrumb { color: rgba(200,168,75,0.7); font-size: 13px; margin-bottom: 16px; }
  .ls6-breadcrumb a { color: var(--ls6-gold-light); text-decoration: none; }
  .ls6-breadcrumb a:hover { text-decoration: underline; }
  .ls6-hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(200,168,75,0.15); border: 1px solid rgba(200,168,75,0.4);
    color: var(--ls6-gold-light); padding: 6px 14px; border-radius: 20px;
    font-size: 13px; font-weight: 500; margin-bottom: 20px;
  }
  .ls6-hero h1 {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    color: #fff; font-weight: 700; line-height: 1.15;
    margin: 0 0 12px;
  }
  .ls6-hero h1 span { color: var(--ls6-gold); }
  .ls6-hero-sub { color: rgba(255,255,255,0.7); font-size: 16px; max-width: 560px; margin: 0; line-height: 1.6; }
  .ls6-hero-stats {
    display: flex; gap: 32px; margin-top: 32px; flex-wrap: wrap;
  }
  .ls6-stat { text-align: left; }
  .ls6-stat-num { font-family: 'Crimson Pro', serif; font-size: 2rem; font-weight: 700; color: var(--ls6-gold); line-height: 1; }
  .ls6-stat-label { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 2px; }

  /* INSTRUCTIONS */
  .ls6-instructions {
    background: #fff; border-bottom: 1px solid #ede8df;
    padding: 16px 0;
  }
  .ls6-instructions-inner {
    display: flex; align-items: center; gap: 24px; flex-wrap: wrap;
  }
  .ls6-step {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--ls6-slate);
  }
  .ls6-step-num {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--ls6-gold); color: white;
    font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .ls6-step-arrow { color: #ccc; font-size: 16px; }

  /* CHAPTERS GRID */
  .ls6-body { padding: 48px 0 80px; }
  .ls6-section-title {
    font-family: 'Crimson Pro', serif;
    font-size: 1.5rem; font-weight: 700; color: var(--ls6-ink);
    margin: 0 0 24px; display: flex; align-items: center; gap: 10px;
  }
  .ls6-section-title::after {
    content: ''; flex: 1; height: 1px; background: linear-gradient(to right, #d4c4a0, transparent);
  }

  .chapters-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px; margin-bottom: 48px;
  }
  .chapter-card {
    background: #fff;
    border: 1.5px solid #ede8df;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
  }
  .chapter-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.1); border-color: var(--ch-color, var(--ls6-gold)); }
  .chapter-card.active { border-color: var(--ch-color, var(--ls6-gold)); box-shadow: 0 0 0 3px rgba(200,168,75,0.15); }
  .chapter-card[data-ch="1"] { --ch-color: var(--ch1); --ch-bg: var(--ch1-bg); }
  .chapter-card[data-ch="2"] { --ch-color: var(--ch2); --ch-bg: var(--ch2-bg); }
  .chapter-card[data-ch="3"] { --ch-color: var(--ch3); --ch-bg: var(--ch3-bg); }
  .chapter-card[data-ch="4"] { --ch-color: var(--ch4); --ch-bg: var(--ch4-bg); }
  .chapter-card[data-ch="5"] { --ch-color: var(--ch5); --ch-bg: var(--ch5-bg); }

  .chapter-card-top {
    background: var(--ch-bg); padding: 20px;
    display: flex; align-items: flex-start; gap: 14px;
  }
  .chapter-icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: var(--ch-color); color: white;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0;
  }
  .chapter-num {
    font-size: 11px; font-weight: 600; color: var(--ch-color);
    text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;
  }
  .chapter-title {
    font-family: 'Crimson Pro', serif;
    font-size: 1rem; font-weight: 700; color: var(--ls6-ink);
    line-height: 1.35; margin: 0;
  }
  .chapter-card-bottom {
    padding: 14px 20px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .chapter-lessons {
    font-size: 12px; color: var(--ls6-slate);
    display: flex; align-items: center; gap: 6px;
  }
  .chapter-lessons span {
    background: var(--ch-bg); color: var(--ch-color);
    padding: 3px 8px; border-radius: 10px; font-weight: 600; font-size: 11px;
  }
  .chapter-arrow {
    width: 28px; height: 28px; border-radius: 50%;
    border: 1.5px solid #ede8df;
    display: flex; align-items: center; justify-content: center;
    color: #aaa; font-size: 12px;
    transition: all 0.2s;
  }
  .chapter-card:hover .chapter-arrow, .chapter-card.active .chapter-arrow {
    background: var(--ch-color); border-color: var(--ch-color); color: white;
  }
  .chapter-card.active .chapter-arrow { transform: rotate(90deg); }

  /* LESSONS PANEL */
  .lessons-panel {
    display: none; margin-bottom: 32px;
    background: #fff; border: 1.5px solid #ede8df; border-radius: 16px;
    overflow: hidden; animation: slideDown 0.3s ease;
  }
  .lessons-panel.open { display: block; }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

  .lessons-panel-header {
    padding: 16px 24px; border-bottom: 1px solid #f0ebe0;
    display: flex; align-items: center; gap: 12px;
    background: var(--panel-bg, #fdf6e9);
  }
  .lessons-panel-title {
    font-family: 'Crimson Pro', serif; font-size: 1.1rem; font-weight: 700; color: var(--ls6-ink);
  }
  .lessons-panel-sub { font-size: 12px; color: var(--ls6-slate); }
  .lessons-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1px; background: #f0ebe0;
  }
  .lesson-btn {
    background: #fff; padding: 16px 18px;
    cursor: pointer; transition: all 0.2s;
    display: flex; align-items: center; gap: 10px;
    border: none; text-align: left;
  }
  .lesson-btn:hover { background: var(--btn-bg, #fef9f0); }
  .lesson-btn.active { background: var(--btn-active-bg, #fef3e2); }
  .lesson-num {
    width: 28px; height: 28px; border-radius: 8px;
    background: var(--btn-color, var(--ls6-gold)); color: white;
    font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .lesson-name { font-size: 13px; color: var(--ls6-ink); font-weight: 500; line-height: 1.3; }

  /* MINDMAP VIEWER */
  .mindmap-viewer {
    display: none; border-top: 1px solid #f0ebe0;
    animation: slideDown 0.3s ease;
  }
  .mindmap-viewer.open { display: block; }
  .mindmap-viewer-header {
    padding: 16px 24px 0;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
  }
  .mindmap-viewer-title {
    font-family: 'Crimson Pro', serif; font-size: 1.2rem; font-weight: 700; color: var(--ls6-ink);
  }
  .mindmap-viewer-title small { font-family: 'Be Vietnam Pro', sans-serif; font-size: 12px; color: var(--ls6-slate); font-weight: 400; margin-left: 8px; }
  .mindmap-actions { display: flex; gap: 8px; }
  .mindmap-btn {
    padding: 7px 14px; border-radius: 8px; font-size: 12px; font-weight: 600;
    border: 1.5px solid #ede8df; background: white; cursor: pointer; transition: all 0.2s;
    color: var(--ls6-slate);
  }
  .mindmap-btn:hover { border-color: var(--ls6-gold); color: var(--ls6-brown); }
  .mindmap-btn.primary { background: var(--ls6-gold); border-color: var(--ls6-gold); color: white; }
  .mindmap-btn.primary:hover { background: var(--ls6-brown); border-color: var(--ls6-brown); }

  .mindmap-container {
    padding: 24px;
    overflow-x: auto;
    background: linear-gradient(135deg, #fafaf8 0%, #f5f0e8 100%);
    min-height: 320px;
  }
  .mindmap-placeholder {
    text-align: center; padding: 48px 24px;
    color: var(--ls6-slate);
  }
  .mindmap-placeholder-icon { font-size: 48px; margin-bottom: 12px; opacity: 0.5; }
  .mindmap-placeholder p { font-size: 14px; margin: 0; }
  .mindmap-placeholder .update-note {
    margin-top: 16px; padding: 12px 20px;
    background: rgba(200,168,75,0.08); border: 1px dashed rgba(200,168,75,0.4);
    border-radius: 10px; font-size: 13px; color: var(--ls6-brown);
    display: inline-block;
  }

  /* ACTUAL MINDMAP SVG STYLES */
  .mindmap-wrap { width: 100%; overflow-x: auto; }
  .mindmap-svg { display: block; margin: 0 auto; max-width: 100%; }
  .mm-center { fill: #3d1f06; }
  .mm-center-text { fill: white; font-family: 'Crimson Pro', serif; font-weight: 700; font-size: 13px; }
  .mm-branch { fill: none; stroke-width: 2; opacity: 0.6; }
  .mm-node { rx: 8; }
  .mm-text { font-family: 'Be Vietnam Pro', sans-serif; font-size: 11px; fill: white; font-weight: 600; }
  .mm-sub { font-family: 'Be Vietnam Pro', sans-serif; font-size: 10px; fill: #444; }
  .mm-sub-box { fill: white; stroke-width: 1; rx: 5; }

  /* EDIT HINT */
  .edit-hint {
    background: linear-gradient(to right, #1a0a02, #3d1f06);
    border-radius: 12px; padding: 20px 24px;
    display: flex; align-items: flex-start; gap: 16px;
    margin-top: 32px;
  }
  .edit-hint-icon { font-size: 24px; flex-shrink: 0; margin-top: 2px; }
  .edit-hint h4 { color: var(--ls6-gold); font-size: 15px; margin: 0 0 6px; font-family: 'Crimson Pro', serif; }
  .edit-hint p { color: rgba(255,255,255,0.7); font-size: 13px; margin: 0; line-height: 1.6; }
  .edit-hint code { background: rgba(200,168,75,0.2); color: var(--ls6-gold-light); padding: 1px 5px; border-radius: 4px; font-size: 12px; }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
</style>

<main class="ls6-page">

  <!-- HERO -->
  <section class="ls6-hero">
    <div class="container">
      <div class="ls6-breadcrumb">
        <a href="/">Trang chủ</a> › <a href="/#courses">Khóa học</a> › Lịch sử 6
      </div>
      <div class="ls6-hero-badge">📖 SGK Kết nối tri thức với cuộc sống</div>
      <h1>Lịch sử & Địa lí <span>Lớp 6</span></h1>
      <p class="ls6-hero-sub">Học từng bài qua sơ đồ tư duy trực quan. Chọn chương → chọn bài → xem tóm tắt ngay.</p>
      <div class="ls6-hero-stats">
        <div class="ls6-stat"><div class="ls6-stat-num">5</div><div class="ls6-stat-label">Chương học</div></div>
        <div class="ls6-stat"><div class="ls6-stat-num">20</div><div class="ls6-stat-label">Bài học (Lịch sử)</div></div>
        <div class="ls6-stat"><div class="ls6-stat-num">20</div><div class="ls6-stat-label">Sơ đồ tư duy</div></div>
      </div>
    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="ls6-instructions">
    <div class="container">
      <div class="ls6-instructions-inner">
        <div class="ls6-step"><div class="ls6-step-num">1</div> Chọn một chương bên dưới</div>
        <div class="ls6-step-arrow">→</div>
        <div class="ls6-step"><div class="ls6-step-num">2</div> Chọn bài học cụ thể</div>
        <div class="ls6-step-arrow">→</div>
        <div class="ls6-step"><div class="ls6-step-num">3</div> Xem sơ đồ tư duy tóm tắt</div>
      </div>
    </div>
  </section>

  <!-- MAIN BODY -->
  <section class="ls6-body">
    <div class="container">
      <h2 class="ls6-section-title">📚 5 Chương học — Phần Lịch Sử</h2>

      <!-- CHAPTERS GRID -->
      <div class="chapters-grid">

        <div class="chapter-card" data-ch="1" onclick="toggleChapter(1)">
          <div class="chapter-card-top">
            <div class="chapter-icon">🤔</div>
            <div>
              <div class="chapter-num">Chương 1</div>
              <p class="chapter-title">Vì sao phải học Lịch sử?</p>
            </div>
          </div>
          <div class="chapter-card-bottom">
            <div class="chapter-lessons">📘 <span>3 bài</span> Bài 1 → 3</div>
            <div class="chapter-arrow">▶</div>
          </div>
        </div>

        <div class="chapter-card" data-ch="2" onclick="toggleChapter(2)">
          <div class="chapter-card-top">
            <div class="chapter-icon">🦴</div>
            <div>
              <div class="chapter-num">Chương 2</div>
              <p class="chapter-title">Xã hội nguyên thuỷ</p>
            </div>
          </div>
          <div class="chapter-card-bottom">
            <div class="chapter-lessons">📘 <span>3 bài</span> Bài 4 → 6</div>
            <div class="chapter-arrow">▶</div>
          </div>
        </div>

        <div class="chapter-card" data-ch="3" onclick="toggleChapter(3)">
          <div class="chapter-card-top">
            <div class="chapter-icon">🏛️</div>
            <div>
              <div class="chapter-num">Chương 3</div>
              <p class="chapter-title">Xã hội cổ đại</p>
            </div>
          </div>
          <div class="chapter-card-bottom">
            <div class="chapter-lessons">📘 <span>4 bài</span> Bài 7 → 10</div>
            <div class="chapter-arrow">▶</div>
          </div>
        </div>

        <div class="chapter-card" data-ch="4" onclick="toggleChapter(4)">
          <div class="chapter-card-top">
            <div class="chapter-icon">🗺️</div>
            <div>
              <div class="chapter-num">Chương 4</div>
              <p class="chapter-title">Đông Nam Á từ những thế kỉ tiếp giáp đầu CN đến thế kỉ X</p>
            </div>
          </div>
          <div class="chapter-card-bottom">
            <div class="chapter-lessons">📘 <span>3 bài</span> Bài 11 → 13</div>
            <div class="chapter-arrow">▶</div>
          </div>
        </div>

        <div class="chapter-card" data-ch="5" onclick="toggleChapter(5)">
          <div class="chapter-card-top">
            <div class="chapter-icon">🇻🇳</div>
            <div>
              <div class="chapter-num">Chương 5</div>
              <p class="chapter-title">Việt Nam từ thế kỉ VII TCN đến đầu thế kỉ X</p>
            </div>
          </div>
          <div class="chapter-card-bottom">
            <div class="chapter-lessons">📘 <span>7 bài</span> Bài 14 → 20</div>
            <div class="chapter-arrow">▶</div>
          </div>
        </div>

      </div>

      <!-- LESSONS PANELS (one per chapter) -->

      <!-- CH1 -->
      <div class="lessons-panel" id="panel-ch1" style="--panel-bg: var(--ch1-bg)">
        <div class="lessons-panel-header">
          <div class="chapter-icon" style="background: var(--ch1); width:36px; height:36px; font-size:16px; border-radius:8px; display:flex; align-items:center; justify-content:center;">🤔</div>
          <div>
            <div class="lessons-panel-title">Chương 1 — Vì sao phải học Lịch sử?</div>
            <div class="lessons-panel-sub">Chọn bài để xem sơ đồ tư duy tóm tắt</div>
          </div>
        </div>
        <div class="lessons-grid" style="--btn-color: var(--ch1); --btn-bg: #fef3e2; --btn-active-bg: #fde8c8">
          <button class="lesson-btn" onclick="showMindmap('ch1','b1','Lịch sử và cuộc sống')">
            <div class="lesson-num">1</div>
            <div class="lesson-name">Lịch sử và cuộc sống</div>
          </button>
          <button class="lesson-btn" onclick="showMindmap('ch1','b2','Dựa vào đâu để biết và phục dựng lại lịch sử?')">
            <div class="lesson-num">2</div>
            <div class="lesson-name">Dựa vào đâu để biết và phục dựng lại lịch sử?</div>
          </button>
          <button class="lesson-btn" onclick="showMindmap('ch1','b3','Thời gian trong lịch sử')">
            <div class="lesson-num">3</div>
            <div class="lesson-name">Thời gian trong lịch sử</div>
          </button>
        </div>
        <div class="mindmap-viewer" id="mm-ch1"></div>
      </div>

      <!-- CH2 -->
      <div class="lessons-panel" id="panel-ch2" style="--panel-bg: var(--ch2-bg)">
        <div class="lessons-panel-header">
          <div class="chapter-icon" style="background: var(--ch2); width:36px; height:36px; font-size:16px; border-radius:8px; display:flex; align-items:center; justify-content:center;">🦴</div>
          <div>
            <div class="lessons-panel-title">Chương 2 — Xã hội nguyên thuỷ</div>
            <div class="lessons-panel-sub">Chọn bài để xem sơ đồ tư duy tóm tắt</div>
          </div>
        </div>
        <div class="lessons-grid" style="--btn-color: var(--ch2); --btn-bg: #e8f8ef; --btn-active-bg: #d0f0df">
          <button class="lesson-btn" onclick="showMindmap('ch2','b4','Nguồn gốc loài người')">
            <div class="lesson-num" style="background:var(--ch2)">4</div>
            <div class="lesson-name">Nguồn gốc loài người</div>
          </button>
          <button class="lesson-btn" onclick="showMindmap('ch2','b5','Xã hội nguyên thuỷ')">
            <div class="lesson-num" style="background:var(--ch2)">5</div>
            <div class="lesson-name">Xã hội nguyên thuỷ</div>
          </button>
          <button class="lesson-btn" onclick="showMindmap('ch2','b6','Sự chuyển biến và phân hoá của xã hội nguyên thuỷ')">
            <div class="lesson-num" style="background:var(--ch2)">6</div>
            <div class="lesson-name">Sự chuyển biến và phân hoá của xã hội nguyên thuỷ</div>
          </button>
        </div>
        <div class="mindmap-viewer" id="mm-ch2"></div>
      </div>

      <!-- CH3 -->
      <div class="lessons-panel" id="panel-ch3" style="--panel-bg: var(--ch3-bg)">
        <div class="lessons-panel-header">
          <div class="chapter-icon" style="background: var(--ch3); width:36px; height:36px; font-size:16px; border-radius:8px; display:flex; align-items:center; justify-content:center;">🏛️</div>
          <div>
            <div class="lessons-panel-title">Chương 3 — Xã hội cổ đại</div>
            <div class="lessons-panel-sub">Chọn bài để xem sơ đồ tư duy tóm tắt</div>
          </div>
        </div>
        <div class="lessons-grid" style="--btn-color: var(--ch3); --btn-bg: #e8f4fc; --btn-active-bg: #cce8f7">
