<!DOCTYPE html>
<html lang="vi">
  <%- include('partials/head', { pageTitle, siteName }) %>
  <body>
    <%- include('partials/header', { brand: data.brand }) %>
    <main>

      <section class="hero-section hero-history-bg">
        <div class="container hero-grid">
          <div class="hero-copy reveal">
            <div class="hero-eyebrow-wrap"><span class="eyebrow-dot"></span><p class="eyebrow" style="font-size:2rem; font-weight:800; letter-spacing:0.15em;">Nền tảng học sử bằng trải nghiệm</p></div>
            <h1 style="font-size:2rem; font-style:italic; line-height:1.6;">
              <%= data.hero.title %><br>
              <%= data.hero.titleLine2 %>
              <span style="display:block; text-align:right; font-size:1rem; font-style:italic; color:#888; font-weight:400;">(Hồ Chí Minh)</span>
            </h1>
              <p class="hero-text"><%= data.hero.subtitle %></p>
            <div class="hero-actions">
              <a href="#courses" class="button button-primary pulse-glow"><%= data.hero.primaryAction %> →</a>
              <a href="#games" class="button button-secondary">🎮 <%= data.hero.secondaryAction %></a>
            </div>
            <div class="hero-tags">
              <span>📚 Lớp 6-12</span><span>🎮 Mini game</span><span>🗺️ Bản đồ</span><span>🤖 AI demo</span>
            </div>
          </div>
          <div class="hero-visual reveal" style="transition-delay:.15s">
            <div class="hero-panel main-panel">
              <div class="panel-top">
                <span class="panel-pill">🏆 Trạm Sử Meta </span>
                <span class="panel-note">Platform EdTech</span>
              </div>
              <h3>Học Sử theo cách mới</h3>
              <p>Học theo lớp, theo thời kỳ và theo phương pháp phù hợp với học sinh THCS - THPT.</p>
              <div class="hero-mini-grid">
                <div><strong data-val="7">7</strong><span>khóa học</span></div>
                <div><strong data-val="40">40+</strong><span>game & quiz</span></div>
                <div><strong data-val="120">120+</strong><span>tài liệu</span></div>
                <div><strong>24/7</strong><span>AI demo</span></div>
              </div>
            </div>
            <div class="floating-card card-a"><span class="floating-icon">⭐</span><div><strong>Timeline</strong><small>Học theo mốc</small></div></div>
            <div class="floating-card card-b"><span class="floating-icon">🗺️</span><div><strong>Bản đồ</strong><small>Gắn địa danh</small></div></div>
          </div>
        </div>
      </section>


      <!-- Trust ticker -->
      <div class="trust-ticker" aria-hidden="true">
        <div class="trust-ticker-inner">
          &nbsp;⭐ Việt Sử Quest &nbsp;·&nbsp; 🎮 3 game lịch sử đang hoạt động &nbsp;·&nbsp; 📚 7 khóa học lớp 6-12 &nbsp;·&nbsp; 🃏 Flashcard kiểu Quizlet &nbsp;·&nbsp; 🗺️ Bản đồ tương tác &nbsp;·&nbsp; 🤖 Chatbot AI hỗ trợ 24/7 &nbsp;·&nbsp; 🇻🇳 Lịch sử Việt Nam sinh động &nbsp;·&nbsp; ⭐ Việt Sử Quest &nbsp;·&nbsp; 🎮 3 game lịch sử đang hoạt động &nbsp;·&nbsp; 📚 7 khóa học lớp 6-12 &nbsp;·&nbsp; 🃏 Flashcard kiểu Quizlet &nbsp;·&nbsp; 🗺️ Bản đồ tương tác &nbsp;·&nbsp; 🤖 Chatbot AI hỗ trợ 24/7 &nbsp;·&nbsp; 🇻🇳 Lịch sử Việt Nam sinh động &nbsp;&nbsp;
        </div>
      </div>

      <section class="highlights-section">
        <div class="container">
          <div class="cards-grid four-col">
            <% data.highlights.forEach((item, i) => { %>
              <article class="info-card reveal" style="transition-delay:<%=i*0.07%>s">
                <span class="card-icon"><%= item.icon %></span>
                <h3><%= item.title %></h3>
                <p><%= item.description %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <section id="courses" class="section">
        <div class="container">
          <div class="section-head reveal">
            <div><p class="eyebrow">Khóa học theo lớp</p><h2>Lịch sử <span style="color:#ff7a1a">6</span> – Kết nối tri thức</h2></div>
            <p class="section-note">5 chương · 20 bài học · Chọn chương để bắt đầu hành trình!</p>
          </div>

          <style>
            /* ── Particles ── */
            .hex-particles { position:absolute; inset:0; pointer-events:none; overflow:hidden; z-index:0; }
            .hex-particle { position:absolute; font-size:1.2rem; opacity:0; animation: floatUp 6s ease-in-out infinite; }
            @keyframes floatUp {
              0% { opacity:0; transform:translateY(40px) rotate(0deg); }
              20% { opacity:.6; }
              80% { opacity:.4; }
              100% { opacity:0; transform:translateY(-60px) rotate(360deg); }
            }

            /* ── Hexagon wrapper ── */
            .hex-section { position:relative; padding:2rem 0 3rem; }
            .hex-grid {
              display: flex;
              flex-wrap: wrap;
              justify-content: center;
              gap: 0;
              max-width: 900px;
              margin: 0 auto;
            }
            .hex-row { display:flex; justify-content:center; margin-bottom:-16px; }
            .hex-row.offset { margin-left: 112px; }

            /* ── Single hexagon ── */
            .hex-item {
              width: 260px;
              height: 286px;
              position: relative;
              cursor: pointer;
              margin: 16px;
              transition: transform .3s ease, filter .3s;
              animation: hexFlyIn .6s ease both;
            }
            .hex-item:nth-child(1) { animation-delay: .1s; }
            .hex-item:nth-child(2) { animation-delay: .2s; }
            .hex-item:nth-child(3) { animation-delay: .3s; }
            .hex-item:nth-child(4) { animation-delay: .4s; }
            .hex-item:nth-child(5) { animation-delay: .5s; }
            @keyframes hexFlyIn {
              from { opacity:0; transform:translateY(50px) scale(.8); }
              to   { opacity:1; transform:translateY(0) scale(1); }
            }
            .hex-item:hover { transform:translateY(-8px) scale(1.05); filter:brightness(1.1); z-index:2; }
            .hex-item.active { transform:translateY(-6px) scale(1.04); z-index:2; }

            /* Hexagon clip */
            .hex-inner {
              width: 100%;
              height: 100%;
              clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
              position: relative;
              overflow: hidden;
              transition: box-shadow .3s;
            }
            .hex-item:hover .hex-inner {
              box-shadow: 0 0 30px rgba(255,122,26,0.6), 0 0 60px rgba(255,122,26,0.3);
            }
            .hex-item.active .hex-inner {
              box-shadow: 0 0 40px rgba(255,122,26,0.8);
            }

            /* Màu nền mỗi chương */
            .hex-item:nth-child(1) .hex-inner { background: linear-gradient(145deg, #2d6a4f, #52b788); }
            .hex-item:nth-child(2) .hex-inner { background: linear-gradient(145deg, #1d3557, #457b9d); }
            .hex-item:nth-child(3) .hex-inner { background: linear-gradient(145deg, #7b2d00, #c1440e); }
            .hex-item:nth-child(4) .hex-inner { background: linear-gradient(145deg, #5c4a00, #c9a227); }
            .hex-item:nth-child(5) .hex-inner { background: linear-gradient(145deg, #6b0000, #c1121f); }

            /* Ảnh trong hex */
            .hex-img {
              position:absolute; inset:0;
              width:100%; height:100%;
              object-fit:cover;
              opacity:.5;
              transition:opacity .3s, transform .3s;
            }
            .hex-item:hover .hex-img { opacity:.7; transform:scale(1.1); }

            /* Overlay */
            .hex-overlay {
              position:absolute; inset:0;
              background:linear-gradient(to bottom, rgba(0,0,0,.1) 0%, rgba(0,0,0,.55) 100%);
            }

            /* Nội dung */
            .hex-content {
              position:absolute; inset:0;
              display:flex; flex-direction:column;
              align-items:center; justify-content:center;
              text-align:center; padding:1.5rem .75rem;
              z-index:2;
            }
            .hex-num {
              font-size:1rem; font-weight:800; letter-spacing:.15em;
              text-transform:uppercase; color:rgba(255,255,255,1);
              margin-bottom:.3rem;
            }
            .hex-title {
              font-size:1rem; font-weight:800; color:#fff;
              line-height:1.3; margin-bottom:.6rem;
              text-shadow:0 2px 8px rgba(0,0,0,.5);
            }
            .hex-badge {
              font-size:.68rem; font-weight:700; color:#fff;
              background:rgba(255,255,255,.2);
              backdrop-filter:blur(4px);
              padding:.2rem .55rem; border-radius:99px;
              border:1px solid rgba(255,255,255,.3);
              margin-bottom:.5rem;
            }

            /* Progress bar */
            .hex-progress {
              width:70%; height:3px;
              background:rgba(255,255,255,.2);
              border-radius:99px; overflow:hidden;
            }
            .hex-progress-bar {
              height:100%;
              background:linear-gradient(90deg, #ff7a1a, #ffcb6b);
              border-radius:99px;
              width:0%;
              transition:width 1s ease .5s;
            }
            .hex-item.active .hex-progress-bar { width:15%; }

            /* Active glow ring */
            .hex-item.active .hex-inner::after {
              content:'';
              position:absolute; inset:-3px;
              clip-path:polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
              background:transparent;
              border:3px solid rgba(255,200,50,.8);
              pointer-events:none;
            }

            /* Ribbon */
            .hex-ribbon {
              position:absolute; top:28px; right:-2px;
              background:#ff7a1a; color:#fff;
              font-size:.55rem; font-weight:800;
              padding:.2rem .5rem;
              border-radius:4px 0 0 4px;
              z-index:3; letter-spacing:.05em;
              box-shadow:-2px 2px 8px rgba(0,0,0,.3);
            }

            /* 3D tilt effect */
            .hex-item { transform-style:preserve-3d; }

            /* ── Panel bài học ── */
            .hex-lessons-panel {
              display:none; max-width:900px; margin:2rem auto 0;
              background:#fff; border:2px solid #ff7a1a;
              border-radius:20px; padding:1.75rem;
              animation:slideDown .25s ease;
            }
            .hex-lessons-panel.active { display:block; }
            @keyframes slideDown { from{opacity:0;transform:translateY(-10px)} to{opacity:1;transform:translateY(0)} }
            .hex-panel-header {
              display:flex; align-items:center; gap:1rem;
              margin-bottom:1.25rem; padding-bottom:1rem;
              border-bottom:1.5px solid #f0e8e0;
            }
            .hex-panel-img { width:52px; height:52px; object-fit:cover; border-radius:12px; }
            .hex-panel-title { font-size:1.1rem; font-weight:800; color:#1a1a1a; margin:0; }
            .hex-panel-sub { font-size:.82rem; color:#999; margin:.2rem 0 0; }
            .hex-lesson-list { display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:.5rem; }
            .hex-lesson-item {
              display:flex; align-items:center; gap:.75rem;
              padding:.65rem .9rem; border-radius:10px;
              border:1.5px solid #f0e8e0; background:#fafaf8;
              text-decoration:none; color:#1a1a1a; transition:all .15s;
            }
            .hex-lesson-item:hover { border-color:#ff7a1a; background:#fff8f3; transform:translateX(3px); }
            .hex-lesson-num {
              width:30px; height:30px; border-radius:8px;
              background:#fff4ec; color:#ff7a1a;
              font-weight:800; font-size:.8rem;
              display:flex; align-items:center; justify-content:center; flex-shrink:0;
            }
            .hex-lesson-title { flex:1; font-size:.88rem; font-weight:500; }
            .hex-lesson-item:hover .hex-lesson-title { color:#ff7a1a; }

            @media (max-width:768px) {
              .hex-item { width:150px; height:165px; }
              .hex-row.offset { margin-left:80px; }
              .hex-title { font-size:.72rem; }
            }
            @media (max-width:480px) {
              .hex-item { width:120px; height:132px; }
              .hex-row.offset { margin-left:64px; }
            }
          </style>

          <%
            const chapterImages = [
              { src: '/images/chapters/chuong1.png' },
              { src: '/images/chapters/chuong2.png' },
              { src: '/images/chapters/chuong3.jpg' },
              { src: '/images/chapters/chuong4.jpg' },
              { src: '/images/chapters/chuong5.jpg' }
            ];
            const ribbons = ['MỚI', 'MỚI', 'MỚI', 'MỚI', 'MỚI'];
          %>

          <div class="hex-section reveal">
            <!-- Floating particles -->
            <div class="hex-particles" id="hexParticles"></div>

            <!-- Row 1: 3 hexagons -->
            <div class="hex-row">
              <% [0,1,2].forEach(function(i) { var ch = data.lop6Chapters[i]; %>
              <div class="hex-item" id="hex-<%= ch.id %>" onclick="toggleHex('<%= ch.id %>', this)">
                <span class="hex-ribbon"><%= ribbons[i] %></span>
                <div class="hex-inner">
                  <img class="hex-img" src="<%= chapterImages[i].src %>" alt="" onerror="this.style.display='none'">
                  <div class="hex-overlay"></div>
                  <div class="hex-content">
                    <div class="hex-num">Chương <%= ch.number %></div>
                    <div class="hex-title"><%= ch.title %></div>
                    <div class="hex-badge"><%= ch.lessons.length %> bài học</div>
                    <div class="hex-progress"><div class="hex-progress-bar"></div></div>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>

            <!-- Row 2: 2 hexagons (offset) -->
            <div class="hex-row offset">
              <% [3,4].forEach(function(i) { var ch = data.lop6Chapters[i]; %>
              <div class="hex-item" id="hex-<%= ch.id %>" onclick="toggleHex('<%= ch.id %>', this)">
                <span class="hex-ribbon"><%= ribbons[i] %></span>
                <div class="hex-inner">
                  <img class="hex-img" src="<%= chapterImages[i].src %>" alt="" onerror="this.style.display='none'">
                  <div class="hex-overlay"></div>
                  <div class="hex-content">
                    <div class="hex-num">Chương <%= ch.number %></div>
                    <div class="hex-title"><%= ch.title %></div>
                    <div class="hex-badge"><%= ch.lessons.length %> bài học</div>
                    <div class="hex-progress"><div class="hex-progress-bar"></div></div>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- Lesson panels -->
          <% data.lop6Chapters.forEach(function(ch, i) { %>
          <div class="hex-lessons-panel" id="hex-panel-<%= ch.id %>">
            <div class="hex-panel-header">
              <img class="hex-panel-img" src="<%= chapterImages[i].src %>" alt="" onerror="this.style.display='none'">
              <div>
                <div class="hex-panel-title"><%= ch.title %></div>
                <div class="hex-panel-sub">Chương <%= ch.number %> · <%= ch.lessons.length %> bài học</div>
              </div>
            </div>
            <div class="hex-lesson-list">
              <% ch.lessons.forEach(function(lesson) { %>
              <a href="/lop6/bai/<%= lesson.number %>" class="hex-lesson-item">
                <div class="hex-lesson-num">B<%= lesson.number %></div>
                <div class="hex-lesson-title">Bài <%= lesson.number %>. <%= lesson.title %></div>
              </a>
              <% }) %>
            </div>
          </div>
          <% }) %>

        </div>
      </section>




      <section id="methods" class="section section-soft">
        <div class="container">
          <div class="section-head centered reveal">
            <p class="eyebrow">Học Lịch sử với Trạm Sử Meta</p>
            <h2>Hiểu – Xâu chuỗi – Ghi nhớ – Luyện tập</h2>
            <p class="section-note center-note">Hiểu Lịch sử - Học Lịch Sử không còn chán.</p>
          </div>
          <div class="method-steps">
            <% data.methods.forEach((method, index) => { %>
              <article class="step-card step-<%= index + 1 %> reveal" style="transition-delay:<%=index*0.1%>s">
                <p class="step-label"><%= method.step %></p>
                <h3><%= method.title %></h3>
                <p><%= method.description %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container timeline-wrapper">
          <div class="section-head reveal">
            <div><p class="eyebrow">Học theo dòng thời gian</p><h2>Trục timeline dễ nhớ, dễ liên kết</h2></div>
            <a href="#chatbot" class="text-link">Nhờ AI tóm tắt</a>
          </div>
          <p class="timeline-hint reveal" style="transition-delay:.1s">👆 Click vào mỗi mốc để xem chi tiết</p>
          <div class="timeline-row">
            <% data.timeline.forEach((item, i) => { %>
              <article class="timeline-card reveal" style="transition-delay:<%=i*0.06%>s">
                <div class="tl-icon"><%= item.icon %></div>
                <span class="timeline-year"><%= item.year %></span>
                <h3><%= item.title %></h3>
                <p class="tl-desc"><%= item.description %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>
      <section id="games" class="section section-soft">
        <div class="container">
          <div class="section-head reveal">
            <div><p class="eyebrow">XƯỞNG CỔ VẬT</p><h2>Game lịch sử để học sinh vừa chơi vừa nhớ bài</h2></div>
            <p class="section-note">Mỗi trò chơi gắn với bài học và mốc thời gian cụ thể.</p>
          </div>
          <div class="cards-grid four-col">
            <% data.games.forEach((game, i) => { %>
              <article class="game-card <%= game.href ? 'game-card--live' : '' %> reveal" style="transition-delay:<%=i*0.08%>s">
                <div class="game-card-top">
                  <span class="pill"><%= game.type %></span>
                  <% if (game.badge) { %><span class="pill pill-badge <%= game.badge==='SẮP RA'?'pill-soon':'' %>"><%= game.badge %></span><% } %>
                </div>
                <div class="game-emoji"><%= game.emoji %></div>
                <h3><%= game.name %></h3>
                <p><%= game.description %></p>
                <div class="game-detail"><small><%= game.detail %></small></div>
                <% if (game.href) { %>
                  <a href="<%= game.href %>" class="button button-primary small-button game-play-btn">▶ Chơi ngay</a>
                <% } else { %>
                  <button class="button button-secondary small-button" style="opacity:.52;cursor:not-allowed" onclick="showToast('🕐 Game này sắp ra mắt! Hãy chờ nhé.')">Sắp ra mắt</button>
                <% } %>
              </article>
            <% }) %>
          </div>
        </div>
      </section>
<section id="dau-truong-meta" class="section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="eyebrow">ĐẤU TRƯỜNG META</p>
              <h2>5 Game tương tác cho 5 chương Lịch sử 6</h2>
            </div>
            <p class="section-note">Mỗi chương một game độc đáo — vừa học vừa chiến!</p>
          </div>
          <div class="cards-grid four-col" style="grid-template-columns: repeat(3, 1fr);">
            <% [
              { number: 1, name: 'Phòng chứa bí mật', type: 'Kéo & Thả', emoji: '🗂️', desc: 'Phân loại tư liệu lịch sử và giải bài toán thời gian trên trục timeline cổ điển.', chapter: 'Chương 1 · Vì sao phải học lịch sử?' },
              { number: 2, name: 'Giải mã vách đá', type: 'Khám phá', emoji: '🔦', desc: 'Dùng đuốc rọi sáng hang động, khám phá các câu hỏi ẩn trên vách đá nguyên thủy.', chapter: 'Chương 2 · Xã hội nguyên thủy' },
              { number: 3, name: 'La bàn học giả', type: 'Nối thẻ', emoji: '🧭', desc: 'Nối đúng thành tựu văn minh với quốc gia trước khi hết giờ đếm ngược.', chapter: 'Chương 3 · Xã hội cổ đại' },
              { number: 4, name: 'Giao thương Biển Đông', type: 'Quản lý', emoji: '⛵', desc: 'Điều khiển tàu buôn, trả lời câu hỏi để cập bến các vương quốc Đông Nam Á cổ đại.', chapter: 'Chương 4 · Đông Nam Á' },
              { number: 5, name: 'Thành đồng bất khuất', type: 'Tower Defense', emoji: '🏯', desc: 'Trả lời nhanh để bắn lui quân xâm lược, bảo vệ thành trì của người Việt cổ.', chapter: 'Chương 5 · Việt Nam TCN – TK X' }
            ].forEach((g, i) => { %>
              <article class="game-card game-card--live reveal" style="transition-delay:<%=i*0.08%>s">
                <div class="game-card-top">
                  <span class="pill"><%= g.type %></span>
                  <span class="pill pill-badge">MỚI</span>
                </div>
                <div class="game-emoji"><%= g.emoji %></div>
                <h3><%= g.name %></h3>
                <p><%= g.desc %></p>
                <div class="game-detail"><small><%= g.chapter %></small></div>
                <a href="/games/chuong<%= g.number %>.html" class="button button-primary small-button game-play-btn">▶ Chơi ngay</a>
              </article>
            <% }) %>
          </div>
        </div>
      </section>
      <section id="cong-dong" class="section" style="background:#fff8f3; overflow:hidden;">
  <div class="container">
    <div class="section-head centered reveal">
      <p class="eyebrow">CỘNG ĐỒNG TRẠM SỬ META</p>
      <h2>Học sinh nói gì về chúng mình?</h2>
      <p class="section-note center-note">Những trải nghiệm thật từ học sinh.</p>
    </div>
  </div>

  <!-- Băng chuyền ảnh hàng 1 - chạy phải -->
  <div class="gallery-track-wrap">
    <div class="gallery-track track-left">
