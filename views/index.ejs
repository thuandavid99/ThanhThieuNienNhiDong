    <script>
    // Hexagon toggle
    function toggleHex(id, item) {
      const panel = document.getElementById('hex-panel-' + id);
      const isOpen = panel.classList.contains('active');
      document.querySelectorAll('.hex-lessons-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.hex-item').forEach(h => h.classList.remove('active'));
      if (!isOpen) {
        panel.classList.add('active');
        item.classList.add('active');
        panel.scrollIntoView({ behavior:'smooth', block:'nearest' });
      }
    }

    // 3D tilt effect
    document.querySelectorAll('.hex-item').forEach(function(hex) {
      hex.addEventListener('mousemove', function(e) {
        const rect = hex.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width/2;
        const y = e.clientY - rect.top - rect.height/2;
        const tiltX = (y / rect.height) * 20;
        const tiltY = -(x / rect.width) * 20;
        hex.style.transform = `translateY(-8px) scale(1.05) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
      });
      hex.addEventListener('mouseleave', function() {
        hex.style.transform = '';
      });
    });

    // Floating particles
    const particles = ['⚔️','📜','🏛️','🥁','🗺️','⭐','🏯','🛡️'];
    const container = document.getElementById('hexParticles');
    if (container) {
      for (let i = 0; i < 15; i++) {
        const p = document.createElement('span');
        p.className = 'hex-particle';
        p.textContent = particles[Math.floor(Math.random() * particles.length)];
        p.style.left = Math.random() * 100 + '%';
        p.style.top = Math.random() * 100 + '%';
        p.style.animationDelay = Math.random() * 6 + 's';
        p.style.animationDuration = (4 + Math.random() * 4) + 's';
        container.appendChild(p);
      }
    }
    </script>
  <!-- Background Music -->
<audio id="bgMusic" loop>
  <source src="/audio/nhac-nen.mp3" type="audio/mpeg">
</audio>

<style>
.music-btn {
  position: fixed;
  bottom: 24px;
  left: 24px;
  z-index: 9999;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #ff7a1a;
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(255,122,26,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  transition: transform .2s, background .2s;
}
.music-btn:hover { transform: scale(1.1); background: #e06010; }
.music-btn.playing { animation: pulse-music 1.5s ease-in-out infinite; }
@keyframes pulse-music {
  0%, 100% { box-shadow: 0 4px 16px rgba(255,122,26,0.4); }
  50% { box-shadow: 0 4px 28px rgba(255,122,26,0.8); }
}
</style>

<button class="music-btn playing" id="musicBtn" title="Nhạc nền" onclick="toggleMusic()">🎵</button>

<script>
const audio = document.getElementById('bgMusic');
const btn = document.getElementById('musicBtn');

let musicStarted = false;
function startMusic() {
  if (!musicStarted) {
    audio.volume = 0.4;
    audio.play().catch(() => {});
    musicStarted = true;
  }
}
document.addEventListener('click', startMusic, { once: true });
document.addEventListener('scroll', startMusic, { once: true });

function toggleMusic() {
  if (audio.paused) {
    audio.play();
    btn.textContent = '🎵';
    btn.classList.add('playing');
  } else {
    audio.pause();
    btn.textContent = '🔇';
    btn.classList.remove('playing');
  }
}
</script>
<script>
  // Xóa dấu audio khi về trang chủ → vào bài học lại sẽ phát lại
  sessionStorage.removeItem('welcomeAudioPlayed');
</script>
