<script>
/* ── Chapter toggle ─────────────────────────────── */
function toggleChapter(n) {
  const body  = document.getElementById('ch'+n+'-body');
  const icon  = document.getElementById('ch'+n+'-icon');
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  icon.classList.toggle('open', !isOpen);
  icon.textContent = isOpen ? '▶' : '▼';
}

/* ── Progress tracking ─────────────────────────── */
const TOTAL = 18;
let doneSt = JSON.parse(localStorage.getItem('ls6_done') || '{}');
function updateProgress() {
  const n = Object.values(doneSt).filter(Boolean).length;
  document.getElementById('progressPct').textContent = Math.round(n/TOTAL*100) + '%';
  document.getElementById('pbFill').style.width = (n/TOTAL*100) + '%';
  document.getElementById('doneLessons').textContent = n;
  // update check icons
  Object.keys(doneSt).forEach(id => {
    const el = document.getElementById('check-' + id);
    if (el) { el.textContent = doneSt[id] ? '✓' : '○'; el.classList.toggle('done', !!doneSt[id]); }
  });
}
updateProgress();

