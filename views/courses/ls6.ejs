<!-- ════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════ -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap');
*{box-sizing:border-box}
.ls6-page{font-family:'Be Vietnam Pro',sans-serif;background:#fffdf9;min-height:100vh}

/* ── HERO ────────────────────────────────────────── */
.ls6-hero{position:relative;overflow:hidden;background:linear-gradient(135deg,#1f2937 0%,#344054 100%);padding:52px 0 44px;color:#fff}
.ls6-hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 80% 50%,rgba(255,122,26,.18),transparent);pointer-events:none}
.ls6-hero-inner{position:relative;z-index:1}
.ls6-breadcrumb{font-size:.8rem;color:rgba(255,255,255,.55);margin-bottom:18px}
.ls6-breadcrumb a{color:rgba(255,176,103,.9);font-weight:600}
.ls6-hero-content{display:grid;grid-template-columns:1fr auto;gap:32px;align-items:center}
.ls6-badge{display:inline-block;background:rgba(255,122,26,.25);color:#ffb067;border:1px solid rgba(255,122,26,.4);padding:4px 14px;border-radius:999px;font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px}
.ls6-title{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;margin:0 0 8px;color:#fff}
.ls6-subtitle{font-size:1rem;font-weight:600;color:#ffb067;margin:0 0 8px;font-style:italic}
.ls6-desc{font-size:.88rem;color:rgba(255,255,255,.65);margin:0 0 16px}
.ls6-tags{display:flex;gap:8px;flex-wrap:wrap}
.ls6-tags span{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);padding:5px 12px;border-radius:999px;font-size:.78rem;font-weight:600;color:rgba(255,255,255,.85)}
.ls6-hero-stats{display:flex;flex-direction:column;gap:12px}
.ls6-stat{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:14px 24px;text-align:center;min-width:90px}
.ls6-stat-num{font-size:2rem;font-weight:900;color:#ffb067;display:block;line-height:1}
.ls6-stat-lbl{font-size:.7rem;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.08em;font-weight:700}

/* ── BODY ────────────────────────────────────────── */
.ls6-body{padding:36px 0 80px}

/* ── PROGRESS BAR ────────────────────────────────── */
.ls6-progress-bar{background:#fff;border-radius:16px;border:1.5px solid #eaecf0;padding:16px 22px;margin-bottom:28px;display:flex;align-items:center;gap:16px;box-shadow:0 4px 14px rgba(0,0,0,.04);flex-wrap:wrap}
.ls6-pb-label{font-size:.82rem;font-weight:700;color:#667085;flex-shrink:0}
.ls6-pb-track{flex:1;height:8px;background:#f2f4f7;border-radius:999px;overflow:hidden;min-width:120px}
.ls6-pb-fill{height:100%;background:linear-gradient(90deg,#ff7a1a,#ffb067);border-radius:999px;transition:width .5s ease}
.ls6-pb-count{font-size:.82rem;font-weight:700;color:#ff7a1a;flex-shrink:0}

/* ── CHAPTER ─────────────────────────────────────── */
.ls6-chapter{background:#fff;border-radius:20px;border:1.5px solid #eaecf0;margin-bottom:16px;overflow:hidden;box-shadow:0 4px 14px rgba(0,0,0,.04);transition:box-shadow .2s}
.ls6-chapter:hover{box-shadow:0 8px 28px rgba(255,122,26,.08)}
.ls6-ch-header{display:flex;align-items:center;gap:16px;padding:20px 24px;cursor:pointer;transition:background .2s;user-select:none}
.ls6-ch-header:hover{background:#fff8f2}
.ls6-ch-num{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#ff7a1a,#e96508);color:#fff;font-size:1rem;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 12px rgba(255,122,26,.3)}
.ls6-ch-info{flex:1}
.ls6-ch-title{font-size:1.05rem;font-weight:800;color:#1f2937;margin-bottom:3px}
.ls6-ch-meta{font-size:.78rem;color:#667085;font-weight:600}
.ls6-ch-tags{display:flex;gap:6px;flex-shrink:0}
.ls6-tag{background:#fff5eb;color:#bf4f04;border:1px solid rgba(255,122,26,.2);padding:4px 10px;border-radius:999px;font-size:.72rem;font-weight:700}
.ls6-tag-vn{background:#fef2f2;color:#991b1b;border-color:rgba(220,38,38,.2)}
.ls6-ch-chevron{font-size:.9rem;color:#667085;transition:transform .3s;flex-shrink:0;width:24px;text-align:center}
.ls6-ch-chevron.open{transform:rotate(90deg);color:#ff7a1a}

.ls6-ch-body{display:none;border-top:1.5px solid #f2f4f7;padding:20px 24px;animation:slideDown .3s ease}
.ls6-ch-body.open{display:block}
