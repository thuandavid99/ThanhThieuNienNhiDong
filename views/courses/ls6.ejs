/* ── Open lesson modal ──────────────────────────── */
function openLesson(id) {
  const L = LESSONS[id]; if (!L) return;
  const isDone = !!doneSt[id];

  // Build mind map HTML
  const mm = L.mindmap;
  const branchesHTML = mm.branches.map(br => `
    <div class="mm-branch">
      <div class="mm-node ${br.color}">${br.label}</div>
      <div class="mm-leaves">
        ${br.leaves.map(l => `<div class="mm-leaf">${l}</div>`).join('')}
      </div>
    </div>`).join('');

  // Timeline
  const tlHTML = L.timeline ? `
    <div class="ld-section-title">📅 Timeline</div>
    <div class="ld-timeline">
      ${L.timeline.map(t => `<div class="ld-tl-item"><div class="ld-tl-year">${t.year}</div><div class="ld-tl-text">${t.text}</div></div>`).join('')}
    </div>` : '';

  // Key points
  const kpHTML = L.keypoints ? `
    <div class="ld-section-title">🔑 Kiến thức trọng tâm</div>
    <div class="ld-keypoints">
      ${L.keypoints.map(k => `<div class="ld-kp"><strong>${k.title}</strong>${k.text}</div>`).join('')}
    </div>` : '';

  document.getElementById('lessonContent').innerHTML = `
    <div class="ld-header">
      <div class="ld-badge">${L.chapter}</div>
      <div class="ld-title">${L.num} – ${L.title}</div>
      <div class="ld-subtitle">${L.mindmap.root}</div>
    </div>
    <div class="ld-body">
      <div class="ld-funfact">
        <div class="ld-funfact-icon">${L.funfact.icon}</div>
        <div><div class="ld-funfact-label">💡 Biết chưa?</div><div class="ld-funfact-text">${L.funfact.text}</div></div>
      </div>

      <div class="ld-section-title">🧠 Sơ đồ tư duy</div>
      <div class="mindmap">
        <div class="mm-center">
          <div class="mm-root">${mm.root}</div>
          <div class="mm-branches">${branchesHTML}</div>
        </div>
      </div>

      ${kpHTML}
      ${tlHTML}
    </div>
    <div class="ld-footer">
      <span style="font-size:.8rem;color:#9ca3af">Bài ${id.replace('b','')}/18</span>
      <button class="ld-btn-close" onclick="closeLessonModal()">Đóng</button>
      <button class="ld-btn-done ${isDone?'already':''}" id="doneBtn" onclick="markDone('${id}')">
        ${isDone ? '✓ Đã hoàn thành' : '✓ Đánh dấu xong'}
      </button>
    </div>`;

  document.getElementById('lessonModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeLessonModal(e) {
  if (e && e.target !== document.getElementById('lessonModal')) return;
  document.getElementById('lessonModal').classList.remove('open');
  document.body.style.overflow = '';
}

function markDone(id) {
  doneSt[id] = !doneSt[id];
  localStorage.setItem('ls6_done', JSON.stringify(doneSt));
  updateProgress();
  const btn = document.getElementById('doneBtn');
  if (btn) { btn.textContent = doneSt[id] ? '✓ Đã hoàn thành' : '✓ Đánh dấu xong'; btn.classList.toggle('already', !!doneSt[id]); }
}

// Open chapter 5 by default (most important for lớp 6)
toggleChapter(5);
</script>
