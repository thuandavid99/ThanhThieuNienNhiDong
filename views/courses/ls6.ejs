<!DOCTYPE html>
<html lang="vi">
<%- include('../partials/head', { pageTitle, siteName }) %>
<body>
<%- include('../partials/header', { brand }) %>

<main class="ls6-page">

  <!-- ── HERO ──────────────────────────────────────────── -->
  <div class="ls6-hero">
    <div class="ls6-hero-bg"></div>
    <div class="container ls6-hero-inner">
      <nav class="ls6-breadcrumb">
        <a href="/">Trang chủ</a> › <a href="/#courses">Khóa học</a> › <span>Lịch sử 6</span>
      </nav>
      <div class="ls6-hero-content">
        <div class="ls6-hero-left">
          <span class="ls6-badge">Lớp 6 · THCS</span>
          <h1 class="ls6-title">🏺 Lịch sử 6</h1>
          <p class="ls6-subtitle">Buổi đầu dựng nước – từ thủa hồng hoang đến ngàn năm Bắc thuộc</p>
          <p class="ls6-desc">Chương trình <strong>Kết nối tri thức</strong> · 5 chương · 18 bài học · Sơ đồ tư duy từng bài</p>
          <div class="ls6-tags">
            <span>📖 18 bài học</span>
            <span>🧠 Sơ đồ tư duy</span>
            <span>🎯 54 câu quiz</span>
            <span>🤖 AI tóm tắt</span>
          </div>
        </div>
        <div class="ls6-hero-stats">
          <div class="ls6-stat"><span class="ls6-stat-num">5</span><span class="ls6-stat-lbl">Chương</span></div>
          <div class="ls6-stat"><span class="ls6-stat-num">18</span><span class="ls6-stat-lbl">Bài học</span></div>
          <div class="ls6-stat"><span class="ls6-stat-num">54</span><span class="ls6-stat-lbl">Câu quiz</span></div>
        </div>
      </div>
    </div>
  </div>

