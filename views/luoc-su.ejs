<!DOCTYPE html>
<html lang="vi">
<%- include('partials/head', { pageTitle, siteName: brand.name }) %>
<body>
<%- include('partials/header', { brand }) %>

<style>
/* ── Page hero ── */
.ls-hero {
  background: linear-gradient(135deg, #1a0a00 0%, #2d1200 50%, #1a0a00 100%);
  padding: 3rem 1rem 2.5rem;
  text-align: center;
  border-bottom: 2px solid #ff7a1a33;
  position: relative;
  overflow: hidden;
}
.ls-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 0%, #ff7a1a18 0%, transparent 70%);
}
.ls-hero .eyebrow {
  font-size: .75rem; letter-spacing: .18em; color: #ff7a1a;
  text-transform: uppercase; font-weight: 700; margin-bottom: .6rem;
}
.ls-hero h1 {
  font-size: 1.8rem; font-weight: 900; color: #fff;
  line-height: 1.2; margin-bottom: .8rem; position: relative;
}
.ls-hero h1 span { color: #ff7a1a; }
.ls-hero p {
  color: #bbb; font-size: .9rem; max-width: 480px;
  margin: 0 auto; line-height: 1.6; position: relative;
}
.ls-back {
  display: inline-flex; align-items: center; gap: .4rem;
  color: #ff7a1a; font-size: .85rem; font-weight: 600;
  text-decoration: none; margin-bottom: 1.5rem;
  position: relative;
}
.ls-back:hover { text-decoration: underline; }

/* ── Era filter tabs ── */
.era-tabs {
  display: flex; gap: .5rem; justify-content: center;
  flex-wrap: wrap; padding: 1.5rem 1rem 0;
  background: #fff8f3;
}
.era-btn {
  padding: .4rem 1rem; border-radius: 99px;
  border: 1.5px solid #e0d0c0; background: #fff;
  color: #666; cursor: pointer; font-size: .78rem;
  font-weight: 600; transition: all .2s; font-family: inherit;
}
.era-btn.active, .era-btn:hover {
  background: #ff7a1a; border-color: #ff7a1a; color: #fff;
}

/* ── Main roadmap ── */
.ls-container {
  max-width: 860px; margin: 0 auto;
  padding: 2rem 1rem 4rem;
  background: #fff8f3;
}

/* Đường dọc trung tâm */
.roadmap {
  position: relative;
  padding: 0 0 2rem;
}
.roadmap::before {
  content: '';
  position: absolute; left: 50%; top: 0; bottom: 0;
  width: 3px;
  background: linear-gradient(180deg,
    transparent 0%,
    #ff7a1a 5%,
    #ff7a1a 95%,
    transparent 100%
  );
  transform: translateX(-50%);
}

/* Mỗi mốc */
.rm-item {
  display: flex; align-items: flex-start;
  margin-bottom: 2.5rem; position: relative;
  transition: opacity .3s;
}
.rm-item.hidden { display: none; }

/* Trái / Phải luân phiên */
.rm-item:nth-child(odd)  { flex-direction: row; }
.rm-item:nth-child(even) { flex-direction: row-reverse; }

/* Card nội dung */
.rm-card {
  width: calc(50% - 2.5rem);
  background: #fff; border-radius: 16px;
  border: 1.5px solid #f0e0d0;
  overflow: hidden;
  box-shadow: 0 2px 12px #ff7a1a0a;
  transition: all .25s;
}
.rm-card:hover {
  border-color: #ff7a1a;
  box-shadow: 0 6px 24px #ff7a1a18;
  transform: translateY(-3px);
}

/* Ảnh placeholder */
.rm-img {
  width: 100%; height: 130px;
  background: linear-gradient(135deg, #ffe8d0, #ffd0a8);
  display: flex; align-items: center; justify-content: center;
  font-size: 2.8rem; position: relative; overflow: hidden;
}
.rm-img::after {
  content: 'Ảnh sẽ cập nhật';
  position: absolute; bottom: 6px; right: 8px;
  font-size: .6rem; color: #ff7a1a88;
  font-style: italic;
}
/* Khi có ảnh thật thì dùng: */
/* .rm-img img { width:100%; height:100%; object-fit:cover; } */

.rm-body { padding: .9rem 1rem; }
.rm-era-tag {
  font-size: .65rem; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: #ff7a1a;
  background: #fff3ea; padding: .2rem .6rem;
  border-radius: 99px; display: inline-block; margin-bottom: .4rem;
}
.rm-year {
  font-size: 1.1rem; font-weight: 900; color: #1a1a1a;
  margin-bottom: .15rem;
}
.rm-title {
  font-size: .92rem; font-weight: 700; color: #333;
  margin-bottom: .4rem; line-height: 1.3;
}
.rm-desc {
  font-size: .78rem; color: #777; line-height: 1.5;
}

/* Dot trung tâm */
.rm-dot {
  position: absolute; left: 50%; top: 1.5rem;
  transform: translateX(-50%);
  width: 20px; height: 20px; border-radius: 50%;
  background: #ff7a1a; border: 4px solid #fff8f3;
  box-shadow: 0 0 0 2px #ff7a1a;
  z-index: 2; flex-shrink: 0;
}

/* Đường ngang nối card với dot */
.rm-connector {
  position: absolute; top: 2.1rem; height: 2px;
  background: #ff7a1a44; width: calc(50% - 2.5rem);
}
.rm-item:nth-child(odd)  .rm-connector { left: calc(50% - 2.5rem); right: auto; left: 50%; }
.rm-item:nth-child(even) .rm-connector { right: 50%; left: auto; }

/* ── Era divider ── */
.era-divider {
  text-align: center; margin: 2rem 0 1.5rem;
  position: relative; z-index: 2;
}
.era-divider span {
  background: #ff7a1a; color: #fff;
  font-size: .72rem; font-weight: 800; letter-spacing: .15em;
  text-transform: uppercase; padding: .4rem 1.2rem;
  border-radius: 99px; display: inline-block;
}

/* ── Responsive mobile ── */
@media (max-width: 600px) {
  .roadmap::before { left: 1.2rem; }
  .rm-item,
  .rm-item:nth-child(even) { flex-direction: column !important; padding-left: 3rem; }
  .rm-card { width: 100%; }
  .rm-dot { left: 1.2rem; top: .8rem; }
  .rm-connector { display: none; }
  .rm-img { height: 100px; }
}

/* ── Back to top ── */
.back-top {
  display: block; text-align: center; margin-top: 2rem;
  color: #ff7a1a; font-size: .85rem; font-weight: 600;
  text-decoration: none; padding: .8rem;
}
.back-top:hover { text-decoration: underline; }
</style>

<!-- Hero -->
<div class="ls-hero">
  <a href="/" class="ls-back">← Về trang chủ</a>
  <p class="eyebrow">Trạm Sử Meta</p>
  <h1>Lược sử <span>Việt Nam</span></h1>
  <p>Hành trình 4.000 năm dựng nước và giữ nước — từ Kinh Dương Vương đến Đổi Mới</p>
</div>

<!-- Filter tabs -->
<div class="era-tabs">
  <button class="era-btn active" onclick="filterEra('all')">Tất cả</button>
  <button class="era-btn" onclick="filterEra('dung-nuoc')">Dựng nước</button>
  <button class="era-btn" onclick="filterEra('bac-thuoc')">Bắc thuộc</button>
  <button class="era-btn" onclick="filterEra('doc-lap')">Độc lập</button>
  <button class="era-btn" onclick="filterEra('can-hien-dai')">Cận – Hiện đại</button>
</div>

<!-- Roadmap -->
<div class="ls-container">
  <div class="roadmap" id="roadmap">

    <!-- ── DỰNG NƯỚC ── -->
    <div class="era-divider"><span>🏔️ Thời Dựng Nước</span></div>

    <div class="rm-item" data-era="dung-nuoc">
      <div class="rm-card">
        <div class="rm-img">🏔️</div>
        <div class="rm-body">
          <span class="rm-era-tag">Dựng nước</span>
          <div class="rm-year">2879 TCN</div>
          <div class="rm-title">Kinh Dương Vương lập nước Xích Quỷ</div>
          <div class="rm-desc">Nhà nước đầu tiên của người Việt, mở đầu dòng họ Hồng Bàng huyền thoại.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="dung-nuoc">
      <div class="rm-card">
        <div class="rm-img">🐉</div>
        <div class="rm-body">
          <span class="rm-era-tag">Dựng nước</span>
          <div class="rm-year">2524 TCN</div>
          <div class="rm-title">18 đời Hùng Vương — Nhà nước Văn Lang</div>
          <div class="rm-desc">Lạc Long Quân và Âu Cơ sinh 100 con. Kinh đô Phong Châu (Phú Thọ), nền văn minh lúa nước.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="dung-nuoc">
      <div class="rm-card">
        <div class="rm-img">🏰</div>
        <div class="rm-body">
          <span class="rm-era-tag">Dựng nước</span>
          <div class="rm-year">258 TCN</div>
          <div class="rm-title">An Dương Vương lập Âu Lạc, xây thành Cổ Loa</div>
          <div class="rm-desc">Thành Cổ Loa — công trình quân sự kỳ vĩ, biểu tượng của nhà nước Âu Lạc.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <!-- ── BẮC THUỘC ── -->
    <div class="era-divider"><span>⛓️ Thời Bắc Thuộc</span></div>

    <div class="rm-item" data-era="bac-thuoc">
      <div class="rm-card">
        <div class="rm-img">⛓️</div>
        <div class="rm-body">
          <span class="rm-era-tag">Bắc thuộc</span>
          <div class="rm-year">179 TCN</div>
          <div class="rm-title">Triệu Đà thôn tính — 1000 năm Bắc thuộc bắt đầu</div>
          <div class="rm-desc">Âu Lạc rơi vào tay phương Bắc, mở ra giai đoạn đấu tranh giành độc lập lâu dài.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="bac-thuoc">
      <div class="rm-card">
        <div class="rm-img">⚡</div>
        <div class="rm-body">
          <span class="rm-era-tag">Bắc thuộc</span>
          <div class="rm-year">40 SCN</div>
          <div class="rm-title">Hai Bà Trưng khởi nghĩa</div>
          <div class="rm-desc">Trưng Trắc và Trưng Nhị phất cờ khởi nghĩa tại Hát Môn, xưng vương ở Mê Linh — lần đầu giành độc lập.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="bac-thuoc">
      <div class="rm-card">
        <div class="rm-img">🌟</div>
        <div class="rm-body">
          <span class="rm-era-tag">Bắc thuộc</span>
          <div class="rm-year">544</div>
          <div class="rm-title">Lý Bí lập nước Vạn Xuân</div>
          <div class="rm-desc">Khởi nghĩa thắng lợi năm 542, xưng đế năm 544, lập nước Vạn Xuân — khôi phục độc lập.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="bac-thuoc">
      <div class="rm-card">
        <div class="rm-img">⚔️</div>
        <div class="rm-body">
          <span class="rm-era-tag">Bắc thuộc</span>
          <div class="rm-year">938</div>
          <div class="rm-title">Ngô Quyền đại thắng Bạch Đằng</div>
          <div class="rm-desc">Đóng cọc nhọn sông Bạch Đằng, đánh tan quân Nam Hán — chấm dứt hơn 1000 năm Bắc thuộc.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <!-- ── ĐỘC LẬP ── -->
    <div class="era-divider"><span>👑 Thời Độc Lập</span></div>

    <div class="rm-item" data-era="doc-lap">
      <div class="rm-card">
        <div class="rm-img">👑</div>
        <div class="rm-body">
          <span class="rm-era-tag">Độc lập</span>
          <div class="rm-year">968</div>
          <div class="rm-title">Đinh Bộ Lĩnh lập Đại Cồ Việt</div>
          <div class="rm-desc">Thống nhất 12 sứ quân, đặt quốc hiệu Đại Cồ Việt, đóng đô tại Hoa Lư.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="doc-lap">
      <div class="rm-card">
        <div class="rm-img">🏯</div>
        <div class="rm-body">
          <span class="rm-era-tag">Độc lập</span>
          <div class="rm-year">1010</div>
          <div class="rm-title">Lý Công Uẩn dời đô ra Thăng Long</div>
          <div class="rm-desc">Mở đầu thời kỳ phát triển rực rỡ. Năm 1054 đổi tên nước thành Đại Việt.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="doc-lap">
      <div class="rm-card">
        <div class="rm-img">🛡️</div>
        <div class="rm-body">
          <span class="rm-era-tag">Độc lập</span>
          <div class="rm-year">1258 – 1288</div>
          <div class="rm-title">Ba lần thắng quân Mông – Nguyên</div>
          <div class="rm-desc">Nhà Trần dưới sự chỉ huy của Trần Hưng Đạo ba lần đánh bại đế quốc Mông Cổ hùng mạnh.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="doc-lap">
      <div class="rm-card">
        <div class="rm-img">🌿</div>
        <div class="rm-body">
          <span class="rm-era-tag">Độc lập</span>
          <div class="rm-year">1428</div>
          <div class="rm-title">Lê Lợi lập nhà Hậu Lê</div>
          <div class="rm-desc">Sau 10 năm khởi nghĩa Lam Sơn, đuổi quân Minh, lập triều đại hưng thịnh nhất lịch sử phong kiến.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="doc-lap">
      <div class="rm-card">
        <div class="rm-img">⚡</div>
        <div class="rm-body">
          <span class="rm-era-tag">Độc lập</span>
          <div class="rm-year">1789</div>
          <div class="rm-title">Quang Trung đại phá quân Thanh</div>
          <div class="rm-desc">Chỉ trong 5 ngày Tết Kỷ Dậu, đại phá 29 vạn quân Thanh tại Ngọc Hồi – Đống Đa.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="doc-lap">
      <div class="rm-card">
        <div class="rm-img">🗺️</div>
        <div class="rm-body">
          <span class="rm-era-tag">Độc lập</span>
          <div class="rm-year">1802</div>
          <div class="rm-title">Nguyễn Ánh lập nhà Nguyễn — đặt tên Việt Nam</div>
          <div class="rm-desc">Thống nhất đất nước, đặt tên nước là Việt Nam, đóng đô tại Huế.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <!-- ── CẬN HIỆN ĐẠI ── -->
    <div class="era-divider"><span>🇻🇳 Cận – Hiện Đại</span></div>

    <div class="rm-item" data-era="can-hien-dai">
      <div class="rm-card">
        <div class="rm-img">⚓</div>
        <div class="rm-body">
          <span class="rm-era-tag">Cận – Hiện đại</span>
          <div class="rm-year">1858</div>
          <div class="rm-title">Pháp xâm lược Việt Nam</div>
          <div class="rm-desc">Pháp tấn công Đà Nẵng, mở đầu thời kỳ thực dân đô hộ kéo dài gần 100 năm.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="can-hien-dai">
      <div class="rm-card">
        <div class="rm-img">🌹</div>
        <div class="rm-body">
          <span class="rm-era-tag">Cận – Hiện đại</span>
          <div class="rm-year">1930</div>
          <div class="rm-title">Thành lập Đảng Cộng sản Đông Dương</div>
          <div class="rm-desc">Nguyễn Ái Quốc thống nhất các tổ chức, thành lập Đảng — bước ngoặt lịch sử cách mạng.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="can-hien-dai">
      <div class="rm-card">
        <div class="rm-img">⭐</div>
        <div class="rm-body">
          <span class="rm-era-tag">Cận – Hiện đại</span>
          <div class="rm-year">1945</div>
          <div class="rm-title">Cách mạng tháng Tám — Tuyên ngôn Độc lập 2/9</div>
          <div class="rm-desc">Bác Hồ đọc Tuyên ngôn Độc lập tại Ba Đình, khai sinh nước Việt Nam Dân chủ Cộng hòa.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="can-hien-dai">
      <div class="rm-card">
        <div class="rm-img">🚩</div>
        <div class="rm-body">
          <span class="rm-era-tag">Cận – Hiện đại</span>
          <div class="rm-year">1954</div>
          <div class="rm-title">Chiến thắng Điện Biên Phủ</div>
          <div class="rm-desc">56 ngày đêm chiến đấu anh dũng, Đại tướng Võ Nguyên Giáp chỉ huy đập tan cứ điểm Pháp.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="can-hien-dai">
      <div class="rm-card">
        <div class="rm-img">🇻🇳</div>
        <div class="rm-body">
          <span class="rm-era-tag">Cận – Hiện đại</span>
          <div class="rm-year">1975</div>
          <div class="rm-title">Thống nhất đất nước</div>
          <div class="rm-desc">Chiến dịch Hồ Chí Minh lịch sử, 30/4/1975 non sông thu về một mối.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

    <div class="rm-item" data-era="can-hien-dai">
      <div class="rm-card">
        <div class="rm-img">🌱</div>
        <div class="rm-body">
          <span class="rm-era-tag">Cận – Hiện đại</span>
          <div class="rm-year">1986</div>
          <div class="rm-title">Đổi Mới — mở cửa kinh tế</div>
          <div class="rm-desc">Đại hội VI của Đảng đề ra đường lối Đổi Mới, Việt Nam hội nhập và phát triển vượt bậc.</div>
        </div>
      </div>
      <div class="rm-dot"></div>
    </div>

  </div><!-- /roadmap -->

  <a href="#" class="back-top">↑ Lên đầu trang</a>
</div>

<%- include('partials/footer') %>

<script>
function filterEra(era) {
  // Cập nhật tab active
  document.querySelectorAll('.era-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');

  // Hiện/ẩn các mốc
  document.querySelectorAll('.rm-item').forEach(item => {
    if (era === 'all' || item.dataset.era === era) {
      item.classList.remove('hidden');
    } else {
      item.classList.add('hidden');
    }
  });

  // Hiện/ẩn era divider
  document.querySelectorAll('.era-divider').forEach(div => {
    div.style.display = era === 'all' ? 'block' : 'none';
  });
}
</script>

</body>
</html>
